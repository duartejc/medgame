# Cloudflare Pages Configuration
# Este arquivo é MÍNIMO e só pra referência local
# O Dashboard sobrescreve tudo quando você faz deploy via Git

name = "plantao-medgame"
compatibility_date = "2024-12-16"

# Para Pages, NÃO use 'main' ou entry-point — Pages serve Next.js output direto
# Se precisar de Workers + Pages, use a estrutura de _worker.js

# Variáveis de ambiente (configure no Dashboard, não aqui)
# [env.production]
# vars = { DEEPSEEK_MODEL = "deepseek-chat" }

# Secrets (configure no Dashboard: Settings > Environment variables > Secrets)
# DEEPSEEK_API_KEY será uma secret
